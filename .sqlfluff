[sqlfluff]
dialect = tsql
templater = raw
max_line_length = 120
large_file_skip_byte_limit = 0
# LT02: BEGIN/END at col 1 is intentional; LT01: RAISERROR( no-space is repo style
# CV06: GO used as batch separator, not semicolons; ST06: section_name first is intentional
# AM03: ORDER BY without direction on all columns is repo style
# CP02: temp table columns from DBCC IND output use system PascalCase names (PageFID, IAMFID, etc.)
# ST05: repo uses subqueries intentionally in some places (no CTE-only mandate)
exclude_rules = LT02, LT01, CV06, ST06, AM03, CP02, ST05

[sqlfluff:indentation]
indent_unit = space
tab_space_size = 4
indented_joins = false
indented_ctes = false
indented_using_on = false

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.functions]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.types]
capitalisation_policy = upper

[sqlfluff:rules:capitalisation.identifiers]
# Column aliases use lowercase_underscore — warn on UPPER identifiers
capitalisation_policy = lower

[sqlfluff:rules:convention.not_equal]
preferred_not_equal_style = c_style

